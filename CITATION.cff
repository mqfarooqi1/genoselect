version: 0.3.0
date-released: 2026-07-01
license: MIT
repository-code: "https://github.com/mqfarooqi1/genoselect"
keywords:
  - genomics
  - genomic-selection
  - genomic-prediction
  - GBLUP
  - machine-learning
